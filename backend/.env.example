# ============================================================
# RunFit 백엔드 환경 변수
# 이 파일을 복사하여 .env 로 저장 후 실제 값을 채워주세요
# cp .env.example .env
# ============================================================

# [필수] Anthropic Claude API 키
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# [필수] Google Service Account 이메일
# Google Cloud Console > IAM > 서비스 계정에서 생성
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# [필수] Google Service Account 비밀 키
# JSON 키 파일의 "private_key" 값 전체 붙여넣기 (\n 포함)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# [필수] Google Sheets 문서 ID
# 스프레드시트 URL에서 추출: https://docs.google.com/spreadsheets/d/[이 부분]/edit
SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# [선택] 서버 포트 (기본값: 3000)
PORT=3000

# [선택] 실행 환경 (development | production)
NODE_ENV=development

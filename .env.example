# ============================================================
# RunFit 환경변수 템플릿
# 이 파일을 복사해서 backend/.env 를 만들고 실제 값을 채워주세요.
# cp .env.example backend/.env
# ============================================================

# ── Google Sheets DB 설정 ──────────────────────────────────
#
# [개발 환경 (로컬)] 아래 개발용 스프레드시트 ID를 사용하세요.
#   https://docs.google.com/spreadsheets/d/1XmcpXyod39ccYjiEAQjevBa0WvbIaSM0DA8L6-dLqr0
SPREADSHEET_ID=1XmcpXyod39ccYjiEAQjevBa0WvbIaSM0DA8L6-dLqr0

# [상용 환경 (Railway)] Railway 대시보드 환경변수에서 아래 값으로 설정하세요.
#   SPREADSHEET_ID=1xtcYmcHy6HnyBdRtKtZ0Redunu5DrHPJ-SwNrrVUZ-4
#   (이 파일에 직접 수정하지 말 것 — Railway는 .env 파일을 읽지 않습니다)

GOOGLE_CLIENT_EMAIL=ai-evolution-team6-backend@ai-evolution-team6.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<여기에 private_key 값 붙여넣기>\n-----END PRIVATE KEY-----\n"

# ── Claude API 설정 ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ── 서버 설정 ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
